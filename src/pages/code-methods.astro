---
import BaseLayout from "../layouts/BaseLayout.astro";

const methods = [
  ["SQL transformations", "Staging-to-curated models, reporting views, window functions, joins, indexing notes, and optimization examples."],
  ["Python ETL", "Blob ingestion, schema validation, cleaning, enrichment, loading, logging, and orchestration patterns."],
  ["R analysis", "Exploratory analysis, statistical summaries, modeling workflows, diagnostics, and reproducible output generation."],
  ["Validation checks", "Completeness, uniqueness, referential integrity, accepted values, date logic, thresholds, and reconciliation."],
  ["Modeling methods", "Feature preparation, assumptions, evaluation metrics, diagnostics, and limitations for public-safe datasets."],
];
---

<BaseLayout
  title="Code & Methods | Azure Data Project Platform"
  description="Placeholder sections for SQL transformations, Python ETL, R analysis, validation checks, and modeling methods."
>
  <section class="page">
    <p class="eyebrow">Code and methods</p>
    <h1>Technical method placeholders.</h1>
    <p class="lead">
      This area will collect implementation notes and code demonstrations for safe SQL, Python, R,
      validation, and modeling workflows.
    </p>
    <div class="grid two" style="margin-top: 34px;">
      {methods.map(([title, detail]) => (
        <article class="card">
          <h3>{title}</h3>
          <p>{detail}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
