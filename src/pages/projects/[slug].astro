---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects");

  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout title={`${project.data.title} | Azure Data Project Platform`} description={project.data.summary}>
  <section class="page">
    <p class="eyebrow">{project.data.status} technical project</p>
    <h1>{project.data.title}</h1>
    <p class="lead">{project.data.summary}</p>
    <div class="chip-row">
      {project.data.focusAreas.map((area) => <span class="chip">{area}</span>)}
    </div>
    <div class="grid two" style="margin-top: 34px;">
      <article class="card">
        <h3>Azure services planned</h3>
        <div class="chip-row" style="margin-top: 0;">
          {project.data.azureServices.map((service) => <span class="chip">{service}</span>)}
        </div>
      </article>
      <article class="card">
        <h3>Data safety boundary</h3>
        <p>
          This placeholder will only use synthetic or public-safe data. No real SHA data, patient
          data, internal screenshots, internal table names, operational numbers, or confidential
          documents belong here.
        </p>
      </article>
    </div>
  </section>
  <section class="band">
    <div class="band-inner project-body">
      <Content />
    </div>
  </section>
</BaseLayout>
