---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact | Azure Data Project Platform"
  description="Simple contact page for the Azure data project platform."
>
  <section class="page">
    <p class="eyebrow">Contact</p>
    <h1>Simple contact.</h1>
    <p class="lead">
      For now, this page is a lightweight placeholder for public contact details and links you may
      want to add later.
    </p>
    <div class="grid two" style="margin-top: 34px;">
      <article class="card">
        <h3>Email</h3>
        <p>Add a public-safe email address here.</p>
      </article>
      <article class="card">
        <h3>Project links</h3>
        <p>Add GitHub, deployed dashboards, or Azure-hosted demo links when they are ready.</p>
      </article>
    </div>
  </section>
</BaseLayout>
