---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Dashboards & Visuals | Azure Data Project Platform"
  description="Placeholder page for future synthetic dashboard screenshots, Plotly visuals, and Power BI-style outputs."
>
  <section class="page">
    <p class="eyebrow">Visual outputs</p>
    <h1>Dashboards and visuals placeholder.</h1>
    <p class="lead">
      Future sections will hold synthetic dashboard screenshots, Plotly visuals, Power BI-style
      report outputs, QA scorecards, trend views, and architecture-backed reporting examples.
    </p>
    <div class="grid">
      <article class="card">
        <h3>Synthetic screenshots</h3>
        <p>Reserved for public-safe dashboard images generated from synthetic datasets.</p>
      </article>
      <article class="card">
        <h3>Plotly visuals</h3>
        <p>Reserved for interactive or exported Python/R visuals with reproducible sample data.</p>
      </article>
      <article class="card">
        <h3>Power BI-style outputs</h3>
        <p>Reserved for safe report mockups, KPI cards, trend views, and drilldown examples.</p>
      </article>
    </div>
  </section>
</BaseLayout>
